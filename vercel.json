@import "tailwindcss";

@theme {
  --font-syne: 'Syne', sans-serif;
  --font-dm: 'DM Sans', sans-serif;
  --color-bg: #09090f;
  --color-surface: #111119;
  --color-s2: #1b1b27;
  --color-s3: #232333;
  --color-accent: #7c6aff;
  --color-a2: #a855f7;
  --color-muted: #6b6b82;
  --color-kgreen: #22d3a0;
  --color-kamber: #f59e0b;
  --color-kred: #f43f5e;
  --color-kblue: #38bdf8;
}

* {
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

html, body, #root {
  height: 100%;
  overscroll-behavior: none;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: #09090f;
  color: #f0f0f5;
  -webkit-font-smoothing: antialiased;
}

/* Scrollbar */
::-webkit-scrollbar { width: 3px; height: 3px; }
::-webkit-scrollbar-thumb { background: #232333; border-radius: 99px; }

/* Hide scrollbar but keep scroll */
.no-scroll-bar {
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.no-scroll-bar::-webkit-scrollbar { display: none; }

/* Animations */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}
@keyframes shimmer {
  from { background-position: -200% 0; }
  to   { background-position: 200% 0; }
}

.animate-fade-up  { animation: fadeUp  0.28s ease forwards; }
.animate-slide-up { animation: slideUp 0.32s cubic-bezier(0.32,1.2,0.64,1) forwards; }
.animate-pulse-dot { animation: pulse 2s infinite; }

/* Gradient text */
.grad-text {
  background: linear-gradient(135deg, #7c6aff, #a855f7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Card press effect */
.press:active {
  transform: scale(0.97);
  transition: transform 0.1s;
}

/* Bottom sheet handle */
.sheet-handle {
  width: 40px; height: 4px;
  background: #232333;
  border-radius: 99px;
  margin: 0 auto 20px;
}

/* Input */
input:focus, textarea:focus { outline: none; }
input::placeholder, textarea::placeholder { color: #6b6b82; }

/* Safe area padding */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom, 0px); }
